Result of Task 4: Code Review & Performance :

### Snippet 1: API Service

Problems :
1- There's not model for parsing balance data which is too risky and not clean
2- using the full api path without configure app baseUrl const it's will be issue when try to make environments and also if need change in future we can just change the base url
also it's better to make const file for const api endpoints not hardcoded them in service
3- in transferPoints there no result status check so we cannot trigger if it failed or not also has the same full api url problem that we mentioned above
4- json parsing has no try/catch. if backend response shape changed, app can crash or expose raw parsing error
5- timeout and network errors are not handled separately. so the ui cannot show a clear retry message for connection problems

Suggested Fix :

```dart
class ApiConfig {
  const ApiConfig({required this.baseUrl});

  final String baseUrl;
}

class WalletEndpoints {
  const WalletEndpoints._();

  static const String balance = '/wallet/balance';
  static const String transfer = '/wallet/transfer';
}

class WalletService {
  WalletService({
    required http.Client client,
    required ApiConfig config,
  }) : _client = client,
       _config = config;

  final http.Client _client;
  final ApiConfig _config;

  static const _timeout = Duration(seconds: 10);
  static const _headers = <String, String>{
    'Accept': 'application/json',
    'Content-Type': 'application/json',
  };

  Future<PointsBalanceModel> getBalance() async {
    final http.Response response;
    try {
      response = await _client
          .get(_uri(WalletEndpoints.balance), headers: _headers)
          .timeout(_timeout);
    } on TimeoutException {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Wallet request timed out',
      );
    } on http.ClientException {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Network error while loading wallet',
      );
    }

    if (response.statusCode != 200) {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Failed to load wallet balance',
      );
    }

    try {
      return PointsBalanceModel.fromJson(
        json.decode(response.body) as Map<String, dynamic>,
      );
    } catch (_) {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Invalid wallet balance response',
      );
    }
  }

  Future<TransferResultModel> transferPoints({
    required String recipientId,
    required int points,
  }) async {
    final http.Response response;
    try {
      response = await _client
          .post(
            _uri(WalletEndpoints.transfer),
            headers: _headers,
            body: json.encode({
              'recipientId': recipientId,
              'points': points,
            }),
          )
          .timeout(_timeout);
    } on TimeoutException {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Transfer request timed out',
      );
    } on http.ClientException {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Network error while transferring points',
      );
    }

    if (response.statusCode < 200 || response.statusCode >= 300) {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Transfer failed',
      );
    }

    try {
      return TransferResultModel.fromJson(
        json.decode(response.body) as Map<String, dynamic>,
      );
    } catch (_) {
      throw const WalletException(
        WalletExceptionCode.unexpected,
        'Invalid transfer response',
      );
    }
  }

  Uri _uri(String path) {
    return Uri.parse('${_config.baseUrl}$path');
  }
}
```

