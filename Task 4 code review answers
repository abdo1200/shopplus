### Snippet 4: State Management

Problems :
1- LoadWallet has no try/catch. if pharsing fail
2- Balance and transactions are loaded one after one. if requests are independent we can use Future.wait to start them in same time
3- Filter event has no loading/error state.
4- in LoadWallet Pagination is ignored. which is will cause bad performance if list is large
5- Filtering uses the currently displayed list. so after on filter the original list will be lost

Suggested Fix :

```dart
class WalletBloc extends Bloc<WalletEvent, WalletState> {
  WalletBloc({
    required GetWalletBalanceUseCase getBalance,
    required GetWalletTransactionsUseCase getTransactions,
  }) : _getBalance = getBalance,
       _getTransactions = getTransactions,
       super(WalletState()) {
    on<WalletStarted>(_onStarted);
    on<WalletFilterChanged>(_onFilterChanged);
    on<WalletNextPageRequested>(_onNextPageRequested);
  }

  static const int _pageLimit = 10;

  final GetWalletBalanceUseCase _getBalance;
  final GetWalletTransactionsUseCase _getTransactions;

  Future<void> _onStarted(
    WalletStarted event,
    Emitter<WalletState> emit,
  ) async {
    emit(
      state.copyWith(
        isLoading: true,
        currentPage: 1,
        hasMore: true,
        clearLoadError: true,
      ),
    );

    try {
      final results = await Future.wait<Object>([
        _getBalance(),
        _getTransactions(
          const GetTransactionsParams(page: 1, limit: _pageLimit),
        ),
      ]);

      final balance = results[0] as PointsBalanceEntity;
      final page = results[1] as PaginatedTransactionsEntity;

      emit(
        state.copyWith(
          status: WalletStatus.ready,
          balance: balance,
          transactions: page.transactions,
          currentPage: page.page + 1,
          hasMore: page.hasNext,
          isLoading: false,
        ),
      );
    } catch (error) {
      emit(
        state.copyWith(
          isLoading: false,
          loadErrorMessage: _errorMessage(error),
        ),
      );
    }
  }

  Future<void> _onFilterChanged(
    WalletFilterChanged event,
    Emitter<WalletState> emit,
  ) async {
    emit(
      state.copyWith(
        selectedType: event.type,
        transactions: const [],
        isLoading: true,
        currentPage: 1,
        hasMore: true,
        clearSelectedType: event.type == null,
        clearLoadError: true,
      ),
    );

    try {
      final page = await _getTransactions(
        GetTransactionsParams(
          page: 1,
          limit: _pageLimit,
          type: event.type,
        ),
      );

      emit(
        state.copyWith(
          transactions: page.transactions,
          currentPage: page.page + 1,
          hasMore: page.hasNext,
          isLoading: false,
        ),
      );
    } catch (error) {
      emit(
        state.copyWith(
          isLoading: false,
          loadErrorMessage: _errorMessage(error),
        ),
      );
    }
  }

  Future<void> _onNextPageRequested(
    WalletNextPageRequested event,
    Emitter<WalletState> emit,
  ) async {
    if (state.isLoading || state.isPaging || !state.hasMore) return;

    emit(state.copyWith(isPaging: true, clearLoadError: true));

    try {
      final page = await _getTransactions(
        GetTransactionsParams(
          page: state.currentPage,
          limit: _pageLimit,
          type: state.selectedType,
        ),
      );

      emit(
        state.copyWith(
          transactions: [...state.transactions, ...page.transactions],
          currentPage: page.page + 1,
          hasMore: page.hasNext,
          isPaging: false,
        ),
      );
    } catch (error) {
      emit(
        state.copyWith(
          isPaging: false,
          loadErrorMessage: _errorMessage(error),
        ),
      );
    }
  }

  String _errorMessage(Object error) {
    return error.toString().replaceFirst('Exception: ', '').trim();
  }
}
```

